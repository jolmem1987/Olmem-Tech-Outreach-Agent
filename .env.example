# Core
APP_BASE_URL=https://outreach.olmemtech.com
SITE_BASE_URL=https://www.olmemtech.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
CRON_SECRET=replace-with-at-least-32-random-characters
TOKEN_SECRET=replace-with-a-different-long-random-secret

# Admin console (/admin). Required to sign in to the panel; if unset the panel
# refuses all logins. Use a strong, unique password.
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# AI - choose a model supported by your account
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Discovery. Tavily is optional; a private prospect feed can be used instead.
TAVILY_API_KEY=
PROSPECT_FEED_URL=
PROSPECT_FEED_TOKEN=
DISCOVERY_REGIONS=Kenosha WI,Racine WI,Milwaukee WI,Northeast Illinois
MAX_DISCOVERIES_PER_RUN=20
MAX_RESEARCH_PER_RUN=8

# Dynamic offer catalog. Optional JSON endpoint; crawler fallback is automatic.
OUTREACH_CATALOG_URL=https://www.olmemtech.com/api/outreach-catalog
SITE_MAX_PAGES=40
PROSPECT_MAX_PAGES=8

# Fit and automation
MIN_FIT_SCORE=80
AUTONOMOUS_SEND=false
DAILY_SEND_LIMIT=8
CONTACT_COOLDOWN_DAYS=120
ALLOW_NAMED_PUBLIC_EMAILS=false

# SendGrid - use a dedicated authenticated sending subdomain or separate sending domain.
SENDGRID_API_KEY=
SENDING_FROM_EMAIL=Jeff at Olmem Tech <outreach@updates.olmemtech.com>
REPLY_TO_EMAIL=jeff@olmemtech.com
SENDGRID_EVENT_PUBLIC_KEY=
VERIFY_SENDGRID_WEBHOOK=true
TRACK_OPENS=true
TRACK_CLICKS=true

# Required commercial-email footer information
BUSINESS_NAME=Olmem Technical Solutions
BUSINESS_POSTAL_ADDRESS=REPLACE WITH VALID PHYSICAL POSTAL ADDRESS

# Optional push into your existing admin API. The outreach tables can also live
# directly in the same Postgres database your website uses.
LEAD_SYNC_URL=https://www.olmemtech.com/api/admin/outreach-sync
LEAD_SYNC_SECRET=replace-with-a-shared-hmac-secret
